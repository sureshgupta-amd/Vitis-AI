#!/bin/bash
# Vitis AI 6.x Host Environment Setup Script
# Covers UG1787 Chapter 3 Sections 3.2 (Software Setup) and 3.3 (Docker Setup)
#
# ============================================================================
# QUICK START
# ============================================================================
#
# 1. Prerequisites:
#    - Ubuntu/Debian-based Linux system (kernel >= 3.2.0)
#    - At least 50GB free disk space
#    - Required files in the same directory as this script:
#      * vitis_ai_2ve_sdk_v6.1.sh
#      * vitis_ai_2ve_docker_6.1.tgz
#      * vitis_ai_2ve_source_v6.1.tar
#      * vitis_ai_2ve_prebuilt_boot_images_v6.1_RevA.tar (optional)
#      * vitis_ai_2ve_prebuilt_boot_images_v6.1_RevB.tar (optional)
#      Note: At least one boot images file (RevA or RevB) is required
#
# 2. Run the script:
#    chmod +x host_setup
#    ./host_setup
#
# 3. What it does:
#    - Installs git, docker.io, expect, pv (requires sudo)
#    - Creates workspace at ~/vitis_ai_workspace
#    - Extracts boot images and source code
#    - Installs Vitis AI SDK to ~/.local/vitis-ai-sdk
#    - Loads Docker development container
#    - Generates helper scripts
#
# 4. After completion:
#    - Source SDK: source ~/.local/vitis-ai-sdk/environment-setup-*
#    - Run Docker: ~/vitis_ai_workspace/scripts/run_vitis_docker.sh
#
# 5. Options:
#    --auto              Non-interactive mode (accepts all defaults)
#    --force             Force reinstall even if already complete
#    --workspace DIR     Custom workspace directory (default: ~/vitis_ai_workspace)
#    --sdk-path PATH     Custom SDK installation path (default: ~/.local/vitis-ai-sdk)
#    --download-dir DIR  Custom download directory (default: script directory)
#    --help              Show this help message
#
# ============================================================================
#
# This is a self-contained script -- no external config or library files required.
#
# This script does NOT require root/sudo privileges for most operations.
# The install_host_packages step uses sudo to install system packages via apt.
#
# Usage:
#   ./host_setup [OPTIONS]
#
# Options:
#   --auto              Non-interactive mode
#   --force             Force reinstall even if already complete
#   --workspace DIR     Custom workspace directory
#   --sdk-path PATH     Custom SDK installation path
#   --download-dir DIR  Custom download directory (default: script directory)
#   --help              Show this help message
#

set -e

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ============================================================================
# Inline Configuration (from config.env -- host-relevant variables only)
# ============================================================================

# Workspace Configuration
WORKSPACE_DIR="${WORKSPACE_DIR:-${HOME}/vitis_ai_workspace}"
DOWNLOAD_DIR="${DOWNLOAD_DIR:-${SCRIPT_DIR}}"

# SDK Configuration
SDK_VERSION=""  # Will be detected from available files
MIN_SDK_VERSION="6.1"
SDK_INSTALL_DIR="${SDK_INSTALL_DIR:-${HOME}/.local/vitis-ai-sdk}"
SDK_DEFAULT_PARENT="${HOME}/.local"

# Docker Configuration
DOCKER_IMAGE_NAME="vitis_ai_2ve_docker"
DOCKER_IMAGE_TAG=""  # Will be set based on detected version
DOCKER_FULL_IMAGE=""  # Will be set based on detected version

# File Paths (relative to DOWNLOAD_DIR) - will be set after version detection
SDK_INSTALLER=""
DOCKER_IMAGE_FILE=""
SOURCE_TAR=""
BOOT_IMAGES_TAR_REVA=""
BOOT_IMAGES_TAR_REVB=""

# Installation Options (defaults)
INSTALL_SDK="${INSTALL_SDK:-N}"
INSTALL_DOCKER="${INSTALL_DOCKER:-N}"

# System Requirements
MIN_KERNEL_VERSION="3.2.0"
MIN_DISK_SPACE_GB=50

# Vivado Configuration
VIVADO_VERSION="2025.2"
VIVADO_COMMON_PATHS=(
    "/tools/Xilinx/Vivado/${VIVADO_VERSION}"
    "/opt/Xilinx/Vivado/${VIVADO_VERSION}"
    "${HOME}/Xilinx/Vivado/${VIVADO_VERSION}"
    "/usr/local/Xilinx/Vivado/${VIVADO_VERSION}"
)

# Feature Flags
SKIP_VIVADO_CHECK="${SKIP_VIVADO_CHECK:-false}"
AUTO_MODE="${AUTO_MODE:-false}"
FORCE_REINSTALL="${FORCE_REINSTALL:-false}"
DRY_RUN="${DRY_RUN:-false}"

# Logging / State
LOG_DIR="${WORKSPACE_DIR}/logs"
LOG_FILE="${LOG_DIR}/setup_$(date +%Y%m%d_%H%M%S).log"
STATE_FILE="${WORKSPACE_DIR}/.vitis_setup_state"

# ============================================================================
# Colors and Formatting
# ============================================================================
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    NC='\033[0m'  # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    CYAN=''
    BOLD=''
    NC=''
fi

# ============================================================================
# Logging Functions
# ============================================================================

log() {
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')
    echo -e "${GREEN}[${timestamp}]${NC} $*" | tee -a "${LOG_FILE:-setup.log}"
}

info() {
    echo -e "${BLUE}[INFO]${NC} $*" | tee -a "${LOG_FILE:-setup.log}"
}

warn() {
    echo -e "${YELLOW}[WARNING]${NC} $*" | tee -a "${LOG_FILE:-setup.log}"
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" | tee -a "${LOG_FILE:-setup.log}"
    exit 1
}

success() {
    echo -e "${GREEN}✓${NC} $*" | tee -a "${LOG_FILE:-setup.log}"
}

step() {
    echo -e "\n${CYAN}${BOLD}==>${NC} ${BOLD}$*${NC}" | tee -a "${LOG_FILE:-setup.log}"
}

# ============================================================================
# Utility Functions
# ============================================================================

check_command_warn() {
    local cmd=$1
    local package=${2:-$1}

    if ! command -v "$cmd" >/dev/null 2>&1; then
        warn "$cmd not found. Install with: sudo apt install $package"
        return 1
    fi
    return 0
}

verify_file() {
    local file=$1
    local description=${2:-File}

    if [ ! -f "$file" ]; then
        error "$description not found: $file"
    fi
}

check_disk_space() {
    local required_gb=$1
    local path=$2

    local available_gb
    available_gb=$(df -BG "$path" 2>/dev/null | awk 'NR==2 {print $4}' | sed 's/G//')

    if [ -z "$available_gb" ]; then
        warn "Could not determine available disk space for $path"
        return 1
    fi

    if [ "$available_gb" -lt "$required_gb" ]; then
        error "Insufficient disk space. Required: ${required_gb}GB, Available: ${available_gb}GB at $path"
    fi

    info "Disk space check passed: ${available_gb}GB available (${required_gb}GB required)"
}

confirm() {
    local prompt=$1
    local default=${2:-y}

    if [ "$AUTO_MODE" = "true" ]; then
        log "Auto mode: Proceeding with $prompt"
        return 0
    fi

    local yn
    if [ "$default" = "y" ]; then
        read -p "$prompt [Y/n]: " yn
        yn=${yn:-y}
    else
        read -p "$prompt [y/N]: " yn
        yn=${yn:-n}
    fi

    case $yn in
        [Yy]* ) return 0;;
        * ) return 1;;
    esac
}

# ============================================================================
# State Management (Idempotency)
# ============================================================================

init_state_file() {
    local state_dir
    state_dir=$(dirname "$STATE_FILE")
    mkdir -p "$state_dir"
    touch "$STATE_FILE"
}

mark_complete() {
    local step_name=$1
    init_state_file

    # Remove old entry if exists
    sed -i "/^${step_name}=/d" "$STATE_FILE" 2>/dev/null || true

    # Add new entry with timestamp
    echo "${step_name}=COMPLETE:$(date +%s)" >> "$STATE_FILE"
    success "Completed: $step_name"
}

is_complete() {
    local step_name=$1

    if [ ! -f "$STATE_FILE" ]; then
        return 1
    fi

    grep -q "^${step_name}=COMPLETE" "$STATE_FILE" 2>/dev/null
}

clear_state() {
    local step_name=$1

    if [ -f "$STATE_FILE" ]; then
        sed -i "/^${step_name}=/d" "$STATE_FILE" 2>/dev/null || true
        info "Cleared state: $step_name"
    fi
}

# ============================================================================
# Version Detection
# ============================================================================

detect_version() {
    step "Detecting Vitis AI version from available files"
    
    # Look for version in multiple file types
    local all_files=()
    local version_patterns=(
        "vitis_ai_2ve_sdk_v*.sh"
        "vitis_ai_2ve_docker_*.tgz"
        "vitis_ai_2ve_source_v*.tar"
        "vitis_ai_2ve_prebuilt_boot_images_v*_Rev*.tar"
    )
    
    # Collect all matching files
    for pattern in "${version_patterns[@]}"; do
        while IFS= read -r -d '' file; do
            all_files+=("$file")
        done < <(find "$DOWNLOAD_DIR" -maxdepth 1 -name "$pattern" -print0 2>/dev/null)
    done
    
    if [ ${#all_files[@]} -eq 0 ]; then
        error "No Vitis AI files found in $DOWNLOAD_DIR. Please ensure the required files are present."
    fi
    
    # Extract versions from all found files
    local versions=()
    for file in "${all_files[@]}"; do
        local basename=$(basename "$file")
        
        # Try different version patterns
        # Pattern 1: vitis_ai_2ve_sdk_v6.1.sh or vitis_ai_2ve_source_v6.1.tar
        if [[ $basename =~ vitis_ai_2ve_(sdk|source)_v([0-9]+\.[0-9]+)\.(sh|tar) ]]; then
            local ver="${BASH_REMATCH[2]}"
            versions+=("$ver")
        # Pattern 2: vitis_ai_2ve_docker_6.1.tgz
        elif [[ $basename =~ vitis_ai_2ve_docker_([0-9]+\.[0-9]+)\.tgz ]]; then
            local ver="${BASH_REMATCH[1]}"
            versions+=("$ver")
        # Pattern 3: vitis_ai_2ve_prebuilt_boot_images_v6.1_RevA.tar
        elif [[ $basename =~ vitis_ai_2ve_prebuilt_boot_images_v([0-9]+\.[0-9]+)_Rev[AB]\.tar ]]; then
            local ver="${BASH_REMATCH[1]}"
            versions+=("$ver")
        fi
    done
    
    if [ ${#versions[@]} -eq 0 ]; then
        error "Could not extract version from any Vitis AI files in $DOWNLOAD_DIR"
    fi
    
    # Sort versions and get the highest
    SDK_VERSION=$(printf '%s\n' "${versions[@]}" | sort -V | tail -n1)
    
    # Verify version meets minimum requirement
    if [ "$(printf '%s\n' "$MIN_SDK_VERSION" "$SDK_VERSION" | sort -V | head -n1)" != "$MIN_SDK_VERSION" ]; then
        error "Detected version $SDK_VERSION is lower than minimum supported version $MIN_SDK_VERSION"
    fi
    
    success "Detected Vitis AI version: $SDK_VERSION"
    
    # Set file paths based on detected version
    SDK_INSTALLER="vitis_ai_2ve_sdk_v${SDK_VERSION}.sh"
    DOCKER_IMAGE_FILE="vitis_ai_2ve_docker_${SDK_VERSION}.tgz"
    SOURCE_TAR="vitis_ai_2ve_source_v${SDK_VERSION}.tar"
    BOOT_IMAGES_TAR_REVA="vitis_ai_2ve_prebuilt_boot_images_v${SDK_VERSION}_RevA.tar"
    BOOT_IMAGES_TAR_REVB="vitis_ai_2ve_prebuilt_boot_images_v${SDK_VERSION}_RevB.tar"
    
    # Set Docker tag based on version
    # Note: Docker tag format may vary, using a generic pattern
    DOCKER_IMAGE_TAG="release_v${SDK_VERSION}_0206"
    DOCKER_FULL_IMAGE="${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}"
    
    info "Expected files based on detected version $SDK_VERSION:"
    info "  SDK: $SDK_INSTALLER"
    info "  Docker: $DOCKER_IMAGE_FILE"
    info "  Source: $SOURCE_TAR"
    info "  Boot Images: $BOOT_IMAGES_TAR_REVA / $BOOT_IMAGES_TAR_REVB"
}

# ============================================================================
# System Detection
# ============================================================================

is_wsl() {
    if [ -f /proc/version ]; then
        grep -qi microsoft /proc/version 2>/dev/null
        return $?
    fi
    return 1
}

get_os_info() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$NAME $VERSION_ID"
    else
        echo "Unknown Linux"
    fi
}

check_kernel_version() {
    local min_version=$1
    local current_version
    current_version=$(uname -r | cut -d'-' -f1)

    if [ "$(printf '%s\n' "$min_version" "$current_version" | sort -V | head -n1)" != "$min_version" ]; then
        error "Kernel version $current_version is older than required $min_version"
    fi

    info "Kernel version: $current_version (minimum: $min_version)"
}

is_debian_based() {
    [ -f /etc/debian_version ]
}

# ============================================================================
# Docker Utilities
# ============================================================================

docker_image_exists() {
    local image=$1
    docker images --format "{{.Repository}}:{{.Tag}}" | grep -q "^${image}$"
}

# ============================================================================
# File Extraction Utilities
# ============================================================================

extract_tar() {
    local tar_file=$1
    local target_dir=$2
    local strip_components=${3:-1}

    verify_file "$tar_file" "Archive"
    mkdir -p "$target_dir"

    log "Extracting $(basename "$tar_file") to $target_dir..."

    if [ "$DRY_RUN" = "true" ]; then
        info "DRY RUN: Would extract $tar_file to $target_dir"
        return 0
    fi

    tar -xvf "$tar_file" -C "$target_dir" --strip-components="$strip_components" 2>&1 | \
        grep -E '/$' | \
        while read -r line; do
            echo -ne "\rExtracting: $line"
        done

    echo ""
    log "Extraction completed"
    success "Extraction complete"
}

# ============================================================================
# Summary and Reporting
# ============================================================================

print_next_steps() {
    local steps=("$@")

    echo ""
    echo -e "${CYAN}${BOLD}Next Steps:${NC}"
    local i=1
    for s in "${steps[@]}"; do
        echo "  ${i}. $s"
        i=$((i + 1))
    done
    echo ""
}

# ============================================================================
# Cleanup Functions
# ============================================================================

cleanup_on_error() {
    local s=$1
    warn "Cleaning up after error in: $s"
}

# Register cleanup handler
trap 'cleanup_on_error "unknown"' ERR

# ============================================================================
# Initialization
# ============================================================================

init_logging() {
    local log_dir
    log_dir=$(dirname "$LOG_FILE")
    mkdir -p "$log_dir" 2>/dev/null || true

    if [ -w "$log_dir" ]; then
        touch "$LOG_FILE"
        log "Logging to: $LOG_FILE"
    else
        LOG_FILE="/tmp/vitis_setup_$(date +%Y%m%d_%H%M%S).log"
        warn "Cannot write to configured log directory, using: $LOG_FILE"
    fi
}

# ============================================================================
# Parse Command Line Arguments
# ============================================================================

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --auto)
                AUTO_MODE=true
                shift
                ;;
            --force)
                FORCE_REINSTALL=true
                shift
                ;;
            --skip-vivado)
                SKIP_VIVADO_CHECK=true
                shift
                ;;
            --workspace)
                WORKSPACE_DIR="$2"
                shift 2
                ;;
            --sdk-path)
                SDK_INSTALL_DIR="$2"
                shift 2
                ;;
            --download-dir)
                DOWNLOAD_DIR="$2"
                shift 2
                ;;
            --help)
                show_help
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done

    # Re-derive paths that depend on WORKSPACE_DIR (may have changed via --workspace)
    LOG_DIR="${WORKSPACE_DIR}/logs"
    LOG_FILE="${LOG_DIR}/setup_$(date +%Y%m%d_%H%M%S).log"
    STATE_FILE="${WORKSPACE_DIR}/.vitis_setup_state"
}

show_help() {
    cat << EOF
Vitis AI 6.1 Host Environment Setup Script

Usage: $0 [OPTIONS]

Options:
  --auto              Non-interactive mode (use defaults)
  --force             Force reinstall even if already complete
  --skip-vivado       Skip Vivado installation check
  --workspace DIR     Custom workspace directory (default: ~/vitis_ai_workspace)
  --sdk-path PATH     Custom SDK installation path (default: ~/.local/vitis-ai-sdk)
  --download-dir DIR  Directory containing download files (default: script directory)
  --help              Show this help message

