# ============================================================================
# Install SDK
# ============================================================================

install_sdk() {
    step "Installing Vitis AI SDK"
    
    # Check if SDK installation is enabled
    if [ "$INSTALL_SDK" != "Y" ] && [ "$INSTALL_SDK" != "y" ]; then
        info "SDK installation disabled, skipping..."
        return 0
    fi

    if is_complete "INSTALL_SDK" && [ "$FORCE_REINSTALL" != "true" ]; then
        info "SDK already installed, skipping..."

        # Verify existing installation
        local env_script
        env_script=$(find "$SDK_INSTALL_DIR" -name "environment-setup-*" 2>/dev/null | head -n1)
        if [ -f "$env_script" ]; then
            success "SDK found at: $SDK_INSTALL_DIR"
            return 0
        else
            warn "SDK directory exists but environment script not found, reinstalling..."
            clear_state "INSTALL_SDK"
        fi
    fi

    local installer="${DOWNLOAD_DIR}/${SDK_INSTALLER}"
    
    if [ ! -f "$installer" ]; then
        warn "SDK installer not found: $installer"
        info "SDK installation will be skipped"
        return 0
    fi

    # Determine installation directory
    if [ "$AUTO_MODE" != "true" ]; then
        echo ""
        info "SDK will be installed to: $SDK_INSTALL_DIR"
        if ! confirm "Proceed with SDK installation?" "y"; then
            error "SDK installation cancelled by user"
        fi
    fi

    # Create installation directory (should not require sudo with default path)
    local install_parent
    install_parent=$(dirname "$SDK_INSTALL_DIR")

    if [ ! -d "$install_parent" ]; then
        info "Creating installation directory: $install_parent"
        if ! mkdir -p "$install_parent" 2>/dev/null; then
            # If mkdir fails, likely requires elevated privileges
            warn "Installation directory requires elevated privileges: $install_parent"
            info "Attempting with sudo..."
            sudo mkdir -p "$install_parent" || error "Failed to create installation directory"
            warn "Future runs may require sudo for this SDK path"
            warn "Consider using --sdk-path to specify a user-writable location"
        fi
    fi

    # Make installer executable
    chmod +x "$installer"

    # Unset LD_LIBRARY_PATH to avoid conflicts (per UG1787)
    local old_ld_library_path=$LD_LIBRARY_PATH
    unset LD_LIBRARY_PATH

    log "Running SDK installer (this may take several minutes)..."

    # Run installer
    "$installer" -y -d "$SDK_INSTALL_DIR" 2>&1 | tee -a "$LOG_FILE"

    # Restore LD_LIBRARY_PATH
    export LD_LIBRARY_PATH=$old_ld_library_path

    # Verify installation
    local env_script
    env_script=$(find "$SDK_INSTALL_DIR" -name "environment-setup-*" 2>/dev/null | head -n1)

    if [ ! -f "$env_script" ]; then
        error "SDK installation failed - environment script not found"
    fi

    log "SDK installation completed successfully"
    success "SDK installed successfully"
    info "Environment script: $env_script"

    # Test SDK
    log "Testing SDK installation..."
    # shellcheck disable=SC1090
    source "$env_script"

    if [ -n "$CC" ]; then
        # Extract just the compiler name (first word) from CC which may contain flags
        local cc_binary
        cc_binary=$(echo "$CC" | awk '{print $1}')

        if command -v "$cc_binary" >/dev/null 2>&1; then
            success "Cross-compiler available: $cc_binary"
            "$cc_binary" --version 2>/dev/null | head -n1 || true
        else
            warn "Cross-compiler not found in PATH: $cc_binary"
            info "CC variable is set but compiler binary not accessible"
        fi
    else
        warn "CC variable not set by SDK environment"
    fi

    # Ask about adding to bashrc
    if [ "$AUTO_MODE" != "true" ]; then
        echo ""
        if confirm "Add SDK environment to ~/.bashrc?"; then
            if ! grep -q "$env_script" ~/.bashrc; then
                echo "" >> ~/.bashrc
                echo "# Vitis AI SDK environment" >> ~/.bashrc
                echo "source $env_script" >> ~/.bashrc
                success "Added to ~/.bashrc"
            else
                info "Already present in ~/.bashrc"
            fi
        fi
    fi

    mark_complete "INSTALL_SDK"
}

# ============================================================================
# Check Vivado Installation
# ============================================================================

check_vivado() {
    step "Checking for Vivado installation"

    if [ "$SKIP_VIVADO_CHECK" = "true" ]; then
        info "Skipping Vivado check (--skip-vivado)"
        return 0
    fi

    # Check if vivado is in PATH
    if command -v vivado >/dev/null 2>&1; then
        local vivado_path
        vivado_path=$(which vivado)
        success "Vivado found in PATH: $vivado_path"

        # Get version
        local version
        version=$(vivado -version 2>/dev/null | head -n1 | awk '{print $2}')
        info "Vivado version: $version"

        # Store path for later use
        export VIVADO_DIR=$(dirname "$(dirname "$vivado_path")")
        return 0
    fi

    # Check common installation paths
    info "Vivado not found in PATH, checking common locations..."
    for path in "${VIVADO_COMMON_PATHS[@]}"; do
        if [ -f "${path}/bin/vivado" ]; then
            success "Vivado found at: $path"
            export VIVADO_DIR="$path"

            warn "Vivado not in PATH. Add to your environment:"
            echo "    source ${path}/settings64.sh"
            return 0
        fi
    done

    # Not found
    warn "Vivado ${VIVADO_VERSION} not found"
    echo ""
    echo "Vivado is required for:"
    echo "  - Cable driver installation (for JTAG/UART)"
    echo "  - OSPI programming via XSDB"
    echo "  - Hardware platform development"
    echo ""
    echo "Download Vivado from:"
    echo "  https://www.xilinx.com/support/download.html"
    echo ""
    echo "Installation guide: UG973 (Vivado Design Suite User Guide: Release Notes)"
    echo ""

    if [ "$AUTO_MODE" != "true" ]; then
        if ! confirm "Continue without Vivado?"; then
            error "Vivado required to continue"
        fi
    fi
}

# ============================================================================
# Install pv (Pipe Viewer) Locally
# ============================================================================

install_pv_locally() {
    local pv_version="1.8.5"
    local pv_url="https://www.ivarch.com/programs/sources/pv-${pv_version}.tar.gz"
    local build_dir="${WORKSPACE_DIR}/.build"
    local bin_dir="${WORKSPACE_DIR}/bin"

    # Check for required build tools
    if ! command -v gcc >/dev/null 2>&1; then
        warn "gcc not found - cannot build pv locally"
        return 1
    fi

    if ! command -v make >/dev/null 2>&1; then
        warn "make not found - cannot build pv locally"
        return 1
    fi

    mkdir -p "$build_dir" "$bin_dir"

    info "Downloading pv ${pv_version}..."
    if ! curl -L -o "${build_dir}/pv.tar.gz" "$pv_url" 2>&1 | tee -a "$LOG_FILE"; then
        warn "Failed to download pv"
        return 1
    fi

    info "Building pv..."
    (
        cd "$build_dir" || return 1
        tar -xzf pv.tar.gz || return 1
        cd "pv-${pv_version}" || return 1
        ./configure --prefix="${WORKSPACE_DIR}" 2>&1 | tee -a "$LOG_FILE" || return 1
        make 2>&1 | tee -a "$LOG_FILE" || return 1
        cp pv "${bin_dir}/" || return 1
    )

    if [ -x "${bin_dir}/pv" ]; then
        success "Built pv successfully at ${bin_dir}/pv"
        rm -rf "$build_dir"
        return 0
    else
        warn "Failed to build pv"
        return 1
    fi
}

# ============================================================================
# Load Docker Image
# ============================================================================

load_docker_image() {
    step "Loading Docker development container"
    
    # Check if Docker installation is enabled
    if [ "$INSTALL_DOCKER" != "Y" ] && [ "$INSTALL_DOCKER" != "y" ]; then
        info "Docker installation disabled, skipping..."
        return 0
    fi

    # Check if Docker is available
    if ! command -v docker >/dev/null 2>&1; then
        warn "Docker not found, skipping Docker setup"
        return 0
    fi

    if ! docker ps >/dev/null 2>&1; then
        warn "Docker daemon not accessible, skipping Docker setup"
        return 0
    fi

    # Check if image already loaded
    if docker_image_exists "$DOCKER_FULL_IMAGE" && [ "$FORCE_REINSTALL" != "true" ]; then
        success "Docker image already loaded: $DOCKER_FULL_IMAGE"
        return 0
    fi

    local image_file="${DOWNLOAD_DIR}/${DOCKER_IMAGE_FILE}"
    
    if [ ! -f "$image_file" ]; then
        warn "Docker image file not found: $image_file"
        info "Docker installation will be skipped"
        return 0
    fi

    # Check file size
    local size_gb
    size_gb=$(du -BG "$image_file" | cut -f1 | sed 's/G//')
    info "Docker image size: ${size_gb}GB"

    if [ "$AUTO_MODE" != "true" ]; then
        if ! confirm "Load Docker image? (this will take several minutes)"; then
            warn "Skipping Docker image load"
            return 0
        fi
    fi

    log "Loading Docker image (this may take 10-15 minutes)..."

    # Use pv for progress display if available
    local pv_cmd=""
    if command -v pv >/dev/null 2>&1; then
        pv_cmd="pv"
    elif [ -x "${WORKSPACE_DIR}/bin/pv" ]; then
        pv_cmd="${WORKSPACE_DIR}/bin/pv"
    fi

    # Load image with progress bar if pv available
    if [ -n "$pv_cmd" ]; then
        info "Using pv for progress display"
        echo ""
        "$pv_cmd" "$image_file" | docker load 2>&1 | tee -a "$LOG_FILE"
    else
        warn "pv not available - loading without progress bar"
        info "This will take 10-15 minutes with no visible progress"
        echo ""
        docker load -i "$image_file" 2>&1 | tee -a "$LOG_FILE"
    fi

    # Verify image loaded
    if docker_image_exists "$DOCKER_FULL_IMAGE"; then
        log "Docker image loaded successfully"
        success "Docker image loaded successfully"
        docker images "$DOCKER_IMAGE_NAME"
    else
        error "Docker image verification failed"
    fi

    mark_complete "LOAD_DOCKER_IMAGE"
}

# ============================================================================
# Generate Helper Scripts
# ============================================================================

generate_docker_script() {
    step "Generating Docker helper script"

    local script_path="${WORKSPACE_DIR}/scripts/run_vitis_docker.sh"

    # Detect license directory
    local license_dir=""
    local possible_license_dirs=(
        "${HOME}/.Xilinx"
        "/opt/xilinx/.Xilinx"
        "${HOME}/Xilinx"
    )

    for dir in "${possible_license_dirs[@]}"; do
        if [ -d "$dir" ]; then
            license_dir="$dir"
            info "Found license directory: $license_dir"
            break
        fi
    done

    if [ -z "$license_dir" ]; then
        warn "No Xilinx license directory found"
        warn "You may need to set up licenses for Vitis tools"
        license_dir="${HOME}/.Xilinx"
        info "Will create: $license_dir"
        mkdir -p "$license_dir"
    fi

    # Generate script
    cat > "$script_path" << EOF
#!/bin/bash
# Vitis AI Docker Container Launch Script
# Generated by setup_host.sh on $(date)

# Docker image details
IMAGE="${DOCKER_FULL_IMAGE}"

# Check if image exists
if ! docker images --format "{{.Repository}}:{{.Tag}}" | grep -q "^\${IMAGE}\$"; then
    echo "Error: Docker image not found: \${IMAGE}"
    echo "Run setup_host.sh to load the image"
    exit 1
fi

# Launch container
echo "Launching Vitis AI Docker container..."
echo "Image: \${IMAGE}"
echo "Workspace: ${WORKSPACE_DIR}"
echo ""

docker run \\
    --ulimit stack=-1:-1 \\
    -it \\
    --rm \\
    --network host \\
    -v ${license_dir}:/usr/licenses \\
    -v ${WORKSPACE_DIR}:/workspace \\
    "\${IMAGE}" \\
    bash

# Note: Add additional volume mounts as needed:
#   -v /path/to/models:/workspace/models \\
#   -v /path/to/data:/workspace/data \\
EOF

    chmod +x "$script_path"
    success "Created: $script_path"

    mark_complete "GENERATE_SCRIPTS"
}

# ============================================================================
# Main Execution
# ============================================================================

main() {
    # Record start time
    local start_time=$(date +%s)

    echo ""
    echo "========================================"
    echo "  Vitis AI Host Environment Setup"
    echo "========================================"
    echo ""

    # Parse arguments first
    parse_args "$@"

    # Initialize logging early (before any log/info/warn/error calls)
    mkdir -p "${WORKSPACE_DIR}/logs"
    export LOG_DIR="${WORKSPACE_DIR}/logs"
    export LOG_FILE="${LOG_DIR}/setup_$(date +%Y%m%d_%H%M%S).log"

    info "Most operations run as a regular user"
    info "The host-packages step will use sudo for apt"
    echo ""
    
    # Detect version from available files
    detect_version

    # Run setup steps
    preflight_validation
    setup_directories
    install_host_packages       # apt install git, docker.io, expect, pv (requires sudo)
    setup_host_tools            # Must run before SDK (to avoid cross-compilation)
    extract_boot_images
    extract_source
    install_sdk
    # check_vivado              # Vivado check disabled - not required
    load_docker_image
    generate_docker_script

    # Calculate elapsed time
    local end_time=$(date +%s)
    local elapsed=$((end_time - start_time))
    local elapsed_min=$((elapsed / 60))
    local elapsed_sec=$((elapsed % 60))

    # Print summary
    echo ""
    echo "========================================"
    echo "  Setup Complete!"
    echo "========================================"
    echo ""
    success "Workspace: $WORKSPACE_DIR"
    success "SDK: $SDK_INSTALL_DIR"
    if docker_image_exists "$DOCKER_FULL_IMAGE"; then
        success "Docker: $DOCKER_FULL_IMAGE"
    fi
    echo ""
    info "Total time: ${elapsed_min}m ${elapsed_sec}s"
    echo ""

    # Next steps
    print_next_steps \
        "Source SDK environment: source ${SDK_INSTALL_DIR}/environment-setup-*" \
        "Launch Docker container: ${WORKSPACE_DIR}/scripts/run_vitis_docker.sh"

    echo ""
    info "Setup log: $LOG_FILE"
    echo ""
}

# Run main function
main "$@"
