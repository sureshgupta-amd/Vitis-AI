The SDK and workspace are installed to user-writable locations by default.

Note: Docker operations may require adding your user to the docker group:
  sudo usermod -aG docker \$USER
  (then log out and back in)

For more information, see UG1787 Chapter 3.
EOF
}

# ============================================================================
# Preflight Validation
# ============================================================================

preflight_validation() {
    step "Running preflight validation"

    local errors=0
    local warnings=0

    # Check if running as root
    if [ "$EUID" -eq 0 ]; then
        warn "Running as root - SDK installation may have permission issues"
        warnings=$((warnings + 1))
    fi

    # Check OS
    info "Operating System: $(get_os_info)"
    if ! is_debian_based; then
        warn "Not a Debian/Ubuntu-based system - package installation may fail"
        warnings=$((warnings + 1))
    fi

    # Check kernel version
    check_kernel_version "$MIN_KERNEL_VERSION"

    # Check for WSL
    if is_wsl; then
        warn "Running in WSL - some features may not work properly"
        warnings=$((warnings + 1))
    fi

    # Check required commands
    info "Checking required tools..."
    local required_tools=(tar gzip xz python3 git)
    for tool in "${required_tools[@]}"; do
        if check_command_warn "$tool"; then
            echo -n ""  # Silent success
        else
            errors=$((errors + 1))
        fi
    done

    # Check optional commands
    if ! check_command_warn docker docker.io; then
        warn "Docker not found - will not be able to load container image"
        warnings=$((warnings + 1))
    else
        if ! docker ps >/dev/null 2>&1; then
            warn "Docker daemon not accessible - insufficient permissions or daemon not running"
            info "To use Docker without sudo, add your user to the docker group:"
            echo "    sudo usermod -aG docker $USER"
            echo "    # Then log out and back in"
            warnings=$((warnings + 1))
        fi
    fi

    # Check download directory
    if [ ! -d "$DOWNLOAD_DIR" ]; then
        error "Download directory not found: $DOWNLOAD_DIR"
    fi
    info "Download directory: $DOWNLOAD_DIR"

    # Check for SDK installer
    local sdk_file="${DOWNLOAD_DIR}/${SDK_INSTALLER}"
    if [ -f "$sdk_file" ]; then
        local size_mb=$(du -m "$sdk_file" | cut -f1)
        success "Found SDK installer: $(basename "$sdk_file") (${size_mb} MB)"
    else
        warn "SDK installer not found: $(basename "$sdk_file")"
        warn "SDK installation will be skipped"
        INSTALL_SDK="N"
    fi
    
    # Check for Docker image
    local docker_file="${DOWNLOAD_DIR}/${DOCKER_IMAGE_FILE}"
    if [ -f "$docker_file" ]; then
        local size_mb=$(du -m "$docker_file" | cut -f1)
        success "Found Docker image: $(basename "$docker_file") (${size_mb} MB)"
    else
        warn "Docker image not found: $(basename "$docker_file")"
        warn "Docker installation will be skipped"
        INSTALL_DOCKER="N"
    fi
    
    # Check for source tar (required)
    local source_file="${DOWNLOAD_DIR}/${SOURCE_TAR}"
    if [ -f "$source_file" ]; then
        local size_mb=$(du -m "$source_file" | cut -f1)
        success "Found source archive: $(basename "$source_file") (${size_mb} MB)"
    else
        error "Source archive not found: $(basename "$source_file") - This is required"
    fi

    # Check for boot images - at least one revision required
    info "Checking boot images files..."
    local boot_images_reva="${DOWNLOAD_DIR}/${BOOT_IMAGES_TAR_REVA}"
    local boot_images_revb="${DOWNLOAD_DIR}/${BOOT_IMAGES_TAR_REVB}"
    local found_boot_images=false

    if [ -f "$boot_images_reva" ]; then
        local size_mb=$(du -m "$boot_images_reva" | cut -f1)
        success "Found: $(basename "$boot_images_reva") (${size_mb} MB)"
        found_boot_images=true
    else
        info "Rev A boot images not found: $(basename "$boot_images_reva")"
    fi

    if [ -f "$boot_images_revb" ]; then
        local size_mb=$(du -m "$boot_images_revb" | cut -f1)
        success "Found: $(basename "$boot_images_revb") (${size_mb} MB)"
        found_boot_images=true
    else
        info "Rev B boot images not found: $(basename "$boot_images_revb")"
    fi

    if [ "$found_boot_images" = false ]; then
        error "At least one boot images file is required (Rev A or Rev B)"
    fi

    # Check disk space
    info "Checking disk space..."
    check_disk_space "$MIN_DISK_SPACE_GB" "$HOME"

    # Summary
    echo ""
    if [ $errors -gt 0 ]; then
        error "Preflight validation failed with $errors error(s)"
    elif [ $warnings -gt 0 ]; then
        warn "Preflight validation completed with $warnings warning(s)"
        if ! confirm "Continue despite warnings?"; then
            exit 1
        fi
    else
        success "Preflight validation passed"
    fi
}

# ============================================================================
# Directory Structure Setup
# ============================================================================

setup_directories() {
    step "Setting up workspace directory structure"

    if is_complete "SETUP_DIRECTORIES" && [ "$FORCE_REINSTALL" != "true" ]; then
        info "Directories already set up, skipping..."
        return 0
    fi

    # Create main workspace
    mkdir -p "$WORKSPACE_DIR"
    info "Workspace: $WORKSPACE_DIR"

    # Create subdirectories
    local subdirs=(
        "boot_images"
        "source"
        "models"
        "docker_mounts"
        "logs"
        "scripts"
    )

    for subdir in "${subdirs[@]}"; do
        mkdir -p "${WORKSPACE_DIR}/${subdir}"
        success "Created: ${WORKSPACE_DIR}/${subdir}"
    done

    # Set environment variables
    export WORKSPACE_DIR
    export LOG_DIR="${WORKSPACE_DIR}/logs"
    export LOG_FILE="${LOG_DIR}/setup_$(date +%Y%m%d_%H%M%S).log"

    # Initialize logging
    init_logging

    mark_complete "SETUP_DIRECTORIES"
}

# ============================================================================
# Install Host Packages
# ============================================================================

install_host_packages() {
    step "Installing host packages"

    if is_complete "INSTALL_HOST_PACKAGES" && [ "$FORCE_REINSTALL" != "true" ]; then
        info "Host packages already installed, skipping..."
        return 0
    fi

    if ! is_debian_based; then
        warn "Not a Debian/Ubuntu-based system - skipping apt package installation"
        warn "Please install the 'git', 'docker.io', 'expect', and 'pv' packages manually using your system's package manager"
        mark_complete "INSTALL_HOST_PACKAGES"
        return 0
    fi

    local packages=(git docker.io expect pv)

    info "The following packages will be installed via apt: ${packages[*]}"
    info "This step requires sudo privileges and will prompt for password"

    if [ "$DRY_RUN" = "true" ]; then
        info "DRY RUN: Would run sudo apt-get update && sudo apt-get install -y ${packages[*]}"
        mark_complete "INSTALL_HOST_PACKAGES"
        return 0
    fi

    log "Running apt-get update..."
    sudo apt-get update 2>&1 | tee -a "$LOG_FILE"

    log "Installing packages: ${packages[*]}"
    sudo apt-get install -y "${packages[@]}" 2>&1 | tee -a "$LOG_FILE"

    # Verify installation
    for pkg in "${packages[@]}"; do
        # Handle special case: docker.io package provides 'docker' command
        local cmd="$pkg"
        if [ "$pkg" = "docker.io" ]; then
            cmd="docker"
        fi

        if command -v "$cmd" >/dev/null 2>&1; then
            success "$pkg installed successfully"
        else
            warn "$cmd command not found after installation"
        fi
    done

    mark_complete "INSTALL_HOST_PACKAGES"
}

# ============================================================================
# Setup Host Tools
# ============================================================================

setup_host_tools() {
    step "Setting up host tools"

    if is_complete "SETUP_HOST_TOOLS" && [ "$FORCE_REINSTALL" != "true" ]; then
        info "Host tools already set up, skipping..."
        return 0
    fi

    # Check if pv is available (needed for Docker load progress)
    if command -v pv >/dev/null 2>&1; then
        success "pv found in system PATH"
    elif [ -x "${WORKSPACE_DIR}/bin/pv" ]; then
        success "pv found in workspace: ${WORKSPACE_DIR}/bin/pv"
    else
        info "pv not found - will build locally for Docker load progress"
        info "Note: Building now before SDK switches to cross-compilation"

        if install_pv_locally; then
            success "pv built successfully"
        else
            warn "Failed to build pv - Docker load will run without progress bar"
        fi
    fi

    mark_complete "SETUP_HOST_TOOLS"
}

# ============================================================================
# Extract Boot Images
# ============================================================================

extract_boot_images() {
    step "Extracting boot images and overlays"

    if is_complete "EXTRACT_BOOT_IMAGES" && [ "$FORCE_REINSTALL" != "true" ]; then
        info "Boot images already extracted, skipping..."
        return 0
    fi

    local boot_images_reva="${DOWNLOAD_DIR}/${BOOT_IMAGES_TAR_REVA}"
    local boot_images_revb="${DOWNLOAD_DIR}/${BOOT_IMAGES_TAR_REVB}"
    local tar_file=""
    local revision=""

    # Determine which boot images to install
    if [ -f "$boot_images_reva" ] && [ -f "$boot_images_revb" ]; then
        # Both available - ask user to choose
        if [ "$AUTO_MODE" = "true" ]; then
            info "Both Rev A and Rev B boot images found"
            info "Auto mode: Defaulting to Rev B"
            tar_file="$boot_images_revb"
            revision="RevB"
        else
            echo ""
            info "Both Rev A and Rev B boot images are available"
            echo "  Rev A: $(basename "$boot_images_reva")"
            echo "  Rev B: $(basename "$boot_images_revb")"
            echo ""

            local choice
            while true; do
                read -p "Select revision to install [A/B] (default: B): " choice
                choice=${choice:-B}
                case $choice in
                    [Aa]* )
                        tar_file="$boot_images_reva"
                        revision="RevA"
                        break
                        ;;
                    [Bb]* )
                        tar_file="$boot_images_revb"
                        revision="RevB"
                        break
                        ;;
                    * )
                        echo "Please enter A or B"
                        ;;
                esac
            done
        fi
    elif [ -f "$boot_images_reva" ]; then
        # Only Rev A available
        info "Using Rev A boot images"
        tar_file="$boot_images_reva"
        revision="RevA"
    elif [ -f "$boot_images_revb" ]; then
        # Only Rev B available
        info "Using Rev B boot images"
        tar_file="$boot_images_revb"
        revision="RevB"
    else
        # Neither available - should not reach here due to preflight check
        error "No boot images file found"
    fi

    local target_dir="${WORKSPACE_DIR}/boot_images"

    info "Installing boot images: $revision"
    check_disk_space 2 "$WORKSPACE_DIR"

    # Clear target directory if forcing reinstall
    if [ "$FORCE_REINSTALL" = "true" ] && [ -d "$target_dir" ]; then
        warn "Removing existing boot images..."
        rm -rf "$target_dir"
        mkdir -p "$target_dir"
    fi

    extract_tar "$tar_file" "$target_dir" 1

    # Record which revision was installed
    echo "BOOT_IMAGES_REVISION=$revision" > "${WORKSPACE_DIR}/.boot_images_revision"
    success "Installed $revision boot images"

    mark_complete "EXTRACT_BOOT_IMAGES"
}

