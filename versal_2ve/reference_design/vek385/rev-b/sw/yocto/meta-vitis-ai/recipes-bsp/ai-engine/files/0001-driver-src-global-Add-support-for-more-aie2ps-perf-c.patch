 driver/src/global/xaiegbl_regdef.h     |  3 +++
 driver/src/global/xaiegbl_reginit.c    | 17 ++++++++++++----
 driver/src/global/xaiemlgbl_reginit.c  | 28 ++++++++++++++++++--------
 4 files changed, 52 insertions(+), 16 deletions(-)

