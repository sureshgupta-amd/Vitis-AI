+{
+  const guint8 *restrict s = src;
+  guint8 *restrict dr = GET_R_LINE (y);
+  guint8 *restrict dg = GET_G_LINE (y);
+  guint8 *restrict db = GET_B_LINE (y);
+  gint i;
+  for (i = 0; i < width; i++) {
+    dr[i] = s[i * 4 + 1];
+    dg[i] = s[i * 4 + 2];
+    db[i] = s[i * 4 + 3];
+  }
+}
+#define PACK_BGR_BF16P GST_VIDEO_FORMAT_ARGB64, unpack_BGR_BF16P, 1, pack_BGR_BF16P
