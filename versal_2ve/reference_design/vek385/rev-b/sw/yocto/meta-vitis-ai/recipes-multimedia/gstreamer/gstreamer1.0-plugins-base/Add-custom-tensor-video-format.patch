+}
+
+/* RGBA8_C4 (HCWNC4 8-bit RGBA, 4 channels) */
+#define PACK_RGBA8_C4 GST_VIDEO_FORMAT_ARGB, unpack_RGBA8_C4, 1, pack_RGBA8_C4
+static void
+unpack_RGBA8_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  int i;
+  const guint8 *restrict s = GET_LINE (y);
+  guint8 *restrict d = dest;
+
+  s += x * 4;
+
+  for (i = 0; i < width; i++) {
+    d[i * 4 + 0] = s[i * 4 + 3];  /* A */
+    d[i * 4 + 1] = s[i * 4 + 0];  /* R */
+    d[i * 4 + 2] = s[i * 4 + 1];  /* G */
+    d[i * 4 + 3] = s[i * 4 + 2];  /* B */
+  }
+}
+
+static void
+pack_RGBA8_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    const gpointer src, gint sstride, gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], GstVideoChromaSite chroma_site,
+    gint y, gint width)
+{
+  int i;
+  guint8 *restrict d = GET_LINE (y);
+  const guint8 *restrict s = src;
+
+  for (i = 0; i < width; i++) {
+    d[i * 4 + 0] = s[i * 4 + 1];
+    d[i * 4 + 1] = s[i * 4 + 2];
+    d[i * 4 + 2] = s[i * 4 + 3];
+    d[i * 4 + 3] = s[i * 4 + 0];
+  }
+}
+
+/* RGBA_BF16_C4 (HCWNC4 BFloat16 RGBA, 4 channels) */
+#define PACK_RGBA_BF16_C4 GST_VIDEO_FORMAT_ARGB64, unpack_RGBA_BF16_C4, 1, pack_RGBA_BF16_C4
+static void
+unpack_RGBA_BF16_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  int i;
+  const guint16 *restrict s = (const guint16 *) (GET_LINE (y)) + x * 4;
+  guint16 *restrict d = dest;
+
+  for (i = 0; i < width; i++) {
+    d[i * 4 + 0] = (guint16) CLAMP (bf16_to_float (s[3]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 1] = (guint16) CLAMP (bf16_to_float (s[0]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 2] = (guint16) CLAMP (bf16_to_float (s[1]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 3] = (guint16) CLAMP (bf16_to_float (s[2]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    s += 4;
+  }
+}
+
+static void
+pack_RGBA_BF16_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    const gpointer src, gint sstride, gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], GstVideoChromaSite chroma_site,
+    gint y, gint width)
+{
+  int i;
+  const guint16 *restrict s = src;
+  guint16 *restrict d = (guint16 *) GET_LINE (y);
+
+  for (i = 0; i < width; i++) {
+    d[0] = float_to_bf16 ((gfloat) s[i * 4 + 1] / 65535.0f);
+    d[1] = float_to_bf16 ((gfloat) s[i * 4 + 2] / 65535.0f);
+    d[2] = float_to_bf16 ((gfloat) s[i * 4 + 3] / 65535.0f);
+    d[3] = float_to_bf16 ((gfloat) s[i * 4 + 0] / 65535.0f);
+    d += 4;
+  }
+}
+
+/* RGBA_FP16_C4 (HCWNC4 FLOAT RGBA, 4 channels) */
+#define PACK_RGBA_FP16_C4 GST_VIDEO_FORMAT_ARGB64, unpack_RGBA_FP16_C4, 1, pack_RGBA_FP16_C4
+static void
+unpack_RGBA_FP16_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  int i;
+  const guint16 *restrict s = (const guint16 *) (GET_LINE (y)) + x * 4;
+  guint16 *restrict d = dest;
+
+  for (i = 0; i < width; i++) {
+    d[i * 4 + 0] = (guint16) CLAMP (fp16_to_float (s[3]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 1] = (guint16) CLAMP (fp16_to_float (s[0]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 2] = (guint16) CLAMP (fp16_to_float (s[1]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 3] = (guint16) CLAMP (fp16_to_float (s[2]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    s += 4;
+  }
+}
+
+static void
+pack_RGBA_FP16_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    const gpointer src, gint sstride, gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], GstVideoChromaSite chroma_site,
+    gint y, gint width)
+{
+  int i;
+  const guint16 *restrict s = src;
+  guint16 *restrict d = (guint16 *) GET_LINE (y);
+
+  for (i = 0; i < width; i++) {
+    d[0] = float_to_fp16 ((gfloat) s[i * 4 + 1] / 65535.0f);
+    d[1] = float_to_fp16 ((gfloat) s[i * 4 + 2] / 65535.0f);
+    d[2] = float_to_fp16 ((gfloat) s[i * 4 + 3] / 65535.0f);
+    d[3] = float_to_fp16 ((gfloat) s[i * 4 + 0] / 65535.0f);
+    d += 4;
+  }
+}
+
+/* RGBA_FLOAT_C4 (HCWNC4 FLOAT RGBA, 4 channels) */
+#define PACK_RGBA_FLOAT_C4 GST_VIDEO_FORMAT_ARGB64, unpack_RGBA_FLOAT_C4, 1, pack_RGBA_FLOAT_C4
+static void
+unpack_RGBA_FLOAT_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  int i;
+  const float *restrict s = (const float *) (GET_LINE (y)) + x * 4;
+  guint16 *restrict d = dest;
+
+  for (i = 0; i < width; i++) {
+    float r = s[0];
+    float g = s[1];
+    float b = s[2];
+    float a = s[3];
+    d[0] = CLAMP ((gint) (a * 65535.0f + 0.5f), 0, 65535);
+    d[1] = CLAMP ((gint) (r * 65535.0f + 0.5f), 0, 65535);
+    d[2] = CLAMP ((gint) (g * 65535.0f + 0.5f), 0, 65535);
+    d[3] = CLAMP ((gint) (b * 65535.0f + 0.5f), 0, 65535);
+    s += 4;
+    d += 4;
+  }
+}
+
+static void
+pack_RGBA_FLOAT_C4 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    const gpointer src, gint sstride, gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], GstVideoChromaSite chroma_site,
+    gint y, gint width)
+{
+  int i;
+  const guint16 *restrict s = src;
+  float *restrict d = (float *) GET_LINE (y);
+
+  for (i = 0; i < width; i++) {
+    d[0] = s[1] / 65535.0f;
+    d[1] = s[2] / 65535.0f;
+    d[2] = s[3] / 65535.0f;
+    d[3] = s[0] / 65535.0f;
+    d += 4;
+    s += 4;
+  }
+}
+#define PACK_BGR8P GST_VIDEO_FORMAT_ARGB, unpack_BGR8P, 1, pack_BGR8P
+static void
+unpack_BGR8P (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  const guint8 *restrict sr = GET_R_LINE (y);
+  const guint8 *restrict sg = GET_G_LINE (y);
+  const guint8 *restrict sb = GET_B_LINE (y);
+  guint8 *restrict d = dest;
+  gint i;
+  sr += x;
+  sg += x;
+  sb += x;
+  for (i = 0; i < width; i++) {
+    d[i * 4 + 0] = 0xFF;
+    d[i * 4 + 1] = sr[i];
+    d[i * 4 + 2] = sg[i];
+    d[i * 4 + 3] = sb[i];
+  }
+}
