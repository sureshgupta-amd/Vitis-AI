+/* BFloat16 conversion helpers */
+static inline float
+bf16_to_float (guint16 bf16)
+{
+  union {
+    guint32 u;
+    float f;
+  } u;
+  u.u = ((guint32) bf16) << 16;
+  return u.f;
+}
+
+static inline guint16
+float_to_bf16 (float f)
+{
+  union {
+    guint32 u;
+    float f;
+  } u;
+  u.f = f;
+  return (guint16) (u.u >> 16);
+}
+static inline float
+fp16_to_float (guint16 fp16)
+{
+  union {
+    guint32 u;
+    float f;
+  } u;
+  guint32 sign = (fp16 & 0x8000) << 16;
+  guint32 exp = (fp16 & 0x7C00) >> 10;
+  guint32 mant = (fp16 & 0x03FF);
+
+  if (exp == 0) {
+    if (mant == 0) {
+      /* Zero */
+      u.u = sign;
+    } else {
+      /* Denormalized */
+      exp = 127 - 15;
+      while ((mant & 0x0400) == 0) {
+        mant <<= 1;
+        exp--;
+      }
+      mant &= 0x03FF;
+      u.u = sign | (exp << 23) | (mant << 13);
+    }
+  } else if (exp == 0x1F) {
+    /* Inf or NaN */
+    u.u = sign | 0x7F800000 | (mant << 13);
+  } else {
+    /* Normalized */
+    u.u = sign | ((exp + (127 - 15)) << 23) | (mant << 13);
+  }
+  return u.f;
+}
+
+static inline guint16
+float_to_fp16 (float f)
+{
+  union {
+    guint32 u;
+    float f;
+  } u;
+  u.f = f;
+  guint32 sign = (u.u & 0x80000000) >> 16;
+  gint32 exp = ((u.u & 0x7F800000) >> 23) - 127 + 15;
+  guint32 mant = (u.u & 0x007FFFFF);
+
+  if (exp <= 0) {
+    if (exp < -10) {
+      /* Too small, return zero */
+      return (guint16) sign;
+    }
+    /* Denormalized */
+    mant = (mant | 0x00800000) >> (1 - exp);
+    return (guint16) (sign | (mant >> 13));
+  } else if (exp >= 0x1F) {
+    /* Overflow, return infinity */
+    return (guint16) (sign | 0x7C00);
+  }
+  /* Normalized */
+  return (guint16) (sign | (exp << 10) | (mant >> 13));
+}
+
+/* GRAY_FP16 (16-bit grayscale FP16) */
+#define PACK_GRAY_FP16 GST_VIDEO_FORMAT_AYUV64, unpack_GRAY_FP16, 1, pack_GRAY_FP16
+static void
+unpack_GRAY_FP16 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    gpointer dest, const gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], gint x, gint y, gint width)
+{
+  const guint16 *restrict s = (const guint16 *) GET_LINE (y);
+  guint16 *restrict d = dest;
+  gint i;
+
+  s += x;
+
+  for (i = 0; i < width; i++) {
+    guint16 val = (guint16) CLAMP (fp16_to_float (s[i]) * 65535.0f + 0.5f, 0.0f, 65535.0f);
+    d[i * 4 + 0] = 0xFFFF;
+    d[i * 4 + 1] = val;
+    d[i * 4 + 2] = 0x8000;
+    d[i * 4 + 3] = 0x8000;
+  }
+}
+
+static void
+pack_GRAY_FP16 (const GstVideoFormatInfo * info, GstVideoPackFlags flags,
+    const gpointer src, gint sstride, gpointer data[GST_VIDEO_MAX_PLANES],
+    const gint stride[GST_VIDEO_MAX_PLANES], GstVideoChromaSite chroma_site,
+    gint y, gint width)
+{
+  guint16 *restrict d = (guint16 *) GET_LINE (y);
+  const guint16 *restrict s = src;
+  gint i;
+
+  for (i = 0; i < width; i++) {
+    d[i] = float_to_fp16 ((gfloat) s[i * 4 + 1] / 65535.0f);
+  }
+}
+
+/* GRAY_BF16 (16-bit grayscale BFloat16) */
+#define PACK_GRAY_BF16 GST_VIDEO_FORMAT_AYUV64, unpack_GRAY_BF16, 1, pack_GRAY_BF16
